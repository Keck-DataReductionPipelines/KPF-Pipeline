# ccd_stack = '_STACK'

lev1_list = []
outlier_mask_path = config.ARGUMENT.outlier_mask_path


## do spectral extraction including stray light subtracton and build BARY_CORR and do CA-HK extraction after spectral extraction.
#  description: do spectrum extraction based on extraction method (summ or optimal) per fiber per ccd and
#               spectral extraction from CA-HK spectrometer fibers.
#               copy wavelength solution data from wls sample files to produced L1 data.
#  input: 2D fits
#  output: L1 fits
#  variable highlights:
#    lev1_stem: name base of L1 file to produce.
#    output_lev1_file: path of produced L1 file,  /data/L1/<date_dir>/<lev1_stem>_L1.fits
#    lev1_list: a list containing the path of L1 files produced by either spectral extraction or ca_hk extraction.
#
#    for background extraction:
#      order_mask: KPF0 instance, same size as input L0 data, the image distinguishes the orderlet pixels from the non-orderlet pixels.
#    for spectral extraction:
#      output_lev0_flat_rect: fits file with rectified L0 flat data
#      lev0_flat_rect: KPF0 instance for 'output_lev0_flat_rect'
#      b_all_traces: a boolean to indicate if the order trace results for all ccds exist.
#      trace_list: list containing order trace result file for each ccd.
#                  [/data/order_trace/<date_dir_flat>/<flat_stem>_GREEN_CCD.csv (or <flat_stem>_RED_CCD.csv)]
#      b_level1_sp: a boolean to indicate if spectral extraction for each L0 is successful.
#      op_data: KPF1 instance containing spectral extractis_bary_idxon result which is added into op_data extension by extension
#               per specified extension list (order_names) in each ccd iteration.
#      wavecal_data: KPF1 instance per wls sample file.
#    for ca_hk:
#      hk_dark_data: KPF0 for dark data
#      hk_bias_data: KPF0 for bias data
#  primitives:
#    OrderMask: os_bary_idxrder mask
#    ImageProcessing: perform background subtraction
#    SpectralExtraction: spectral extraction
#    ExtCopy: extension copy from the extension of one data model instance to the extension of another
#             (or the same) data model instance.
#    CaHKExtraction: CA HK extraction.

if do_spectral_extraction or do_hk or do_bc:

	# prepare bias, dark data for ca_hk
	if do_hk:
		hk_dark_data = config.ARGUMENT.hk_dark_fits
		hk_bias_data = config.ARGUMENT.hk_bias_fits
		if hk_dark_data:
			hk_dark_data = kpf0_from_fits(input_hk_data_dir + hk_dark_data, data_type = data_type)
		else:
			hk_dark_data = None

		if hk_bias_data:
			hk_bias_data = kpf0_from_fits(input_hk_data_dir + hk_bias_data, data_type=data_type)
		else:
			hk_bias_data = None

	# Initialize order_mask variable, check below for existence to avoid re-opening
	order_mask = None
	master_flat = None

	# loop through ccd and L0 to do spectral extraction
	for input_lev0_file in d2_file_list: 
		# lev0_data is KPF0 instance for input_lev0_file
		TMP = input_lev0_file
		print(TMP)
		lev0_data = kpf0_from_fits(input_lev0_file, data_type=data_type)
		dt_string = GetHeaderValue(lev0_data, 'DATE-MID')
		cals = CalibrationLookup(dt_string)
		start_order = cals['start_order']
		output_order_trace = cals['ordertrace']
		order_trace_flat = cals['traceflat']
		smooth_lamp_file = str_replace(cals['smoothlamp'], '.fits', '_L1.fits')

		_, short_lev0_file = split(input_lev0_file)
		lev1_stem, lev1_ext = splitext(short_lev0_file)

		# lev1_stem is w/o "_2D" suffix
		if lev0_stem_suffix != None:
			if lev0_stem_suffix in lev1_stem:
				lev1_stem = str_replace(lev1_stem, lev0_stem_suffix, "")
		# output_lev1_file = output_extraction + lev1_stem + lev1_stem_suffix + fits_ext
		output_lev1_file = str_replace(input_lev0_file, '2D', 'L1') 
		output_lev1_file_temp = str_replace(input_lev0_file, '2D', 'L1_temp') 

		is_raw = 1
		# if rect_method in input_lev0_file:
		#    is_raw = 0
		# if lev1_stem_suffix in input_lev0_file:
		#    is_raw = 0
		# if lev2_stem_suffix in input_lev0_file:
		#    is_raw = 0


		# produce level 1 by spectral extraction if overwrite or L1 file doesn't exist
		if (overwrite or not exists(output_lev1_file)):		# Define the order mask - load from CalibrationLookup result
			order_mask_file = cals['ordermask']
			# Load order_mask if not already loaded from file loop
			#  If multiple dates are called in this loop, this will load the wrong mask.
			if order_mask == None:
				order_mask = kpf0_from_fits(order_mask_file, data_type)
				stray_light_output_list = StrayLight(lev0_data, order_mask)
				lev0_data = stray_light_output_list[1]
			if master_flat == None:
				master_flat = kpf0_from_fits(cals['flat'])
			print("SPECTRALEXTRACTION STARTING FOR: "+input_lev0_file)


			spectral_extraction_output_list = SpectralExtraction(lev0_data, 
																 master_flat, 
																 cals['ordertrace'][0], 
																 cals['ordertrace'][1], 
																 cals['start_order'][0], 
																 cals['start_order'][1]
																)
			# SpectralExtraction returns [exit_code, op_data, ...other values...]
			output_data= spectral_extraction_output_list[1]

			output_data = kpf1_from_fits(output_lev1_file, data_type = data_type) #remove when done with testing

			# Remove this conditional. Do quality control only at the very end
			# if output_data != None:
			# 	# Quality Control & Diagnostics - L1 level
			# 	# (this should be moved below CaHK, but there are several to_fits calls for L1 -- let's fix this)
			# 	data_level_str = 'L1'
			# 	kpf_object = output_data
			# 	obj = GetHeaderValue(kpf_object, 'OBJECT')
			# 	invoke_subrecipe("./recipes/quality_control.subrecipe")
			# 	invoke_subrecipe("./recipes/diagnostics.subrecipe")
			# 	output_data = kpf_object
			# result = to_fits(output_data, output_lev1_file)

			# The wavelength solution extensions are not copied into L1 by the new Spectral Extraction. 
			# Copy them here manually.
			# HTI: I added this for loop of copying the WLS but this may be old code that should never be used.
			for idx in ccd_idx:
				if wave_fits[idx] != None and exists(wave_fits[idx]):
				# wavecal_data will be replaced by wavelength interpolation.
					wavecal_data = kpf1_from_fits(wave_fits[idx], data_type=data_type)
					for ext in wave_to_ext[idx]:
						ExtCopy(wavecal_data, ext, ext, to_data_model=output_data) # only this needs changed.
			SetHeaderValue(output_data, 'WLSFILE', wave_fits[0])
			print("Copying WLS files into L1")


			# result = to_fits(output_data, output_lev1_file_temp) # REMOVE WHEN DONE WITH TESTING.
# You can comment out here up to before StrayLight for testing BC.
			# You can read in a file that was created with the main DRP here: 
			#    This allows testing the code below here quickly.

			# Use output_lev1_file_temp to use a file created with this DRP, but skip the parts that take along time.
			# output_data = kpf1_from_fits(output_lev1_file_temp, data_type=data_type) # REMOVE WHEN DONE WITH TESTING.
			# Use this output_lev1_file to use a file created with the master branch drp (copy it to here).
			# output_data = kpf1_from_fits(output_lev1_file, data_type=data_type) # REMOVE WHEN DONE WITH TESTING.

			# copy wls to the proper extension of lev1 data
			if do_sp_wavecopy:# and exists(output_lev1_file): output_lev1 only exists in memory
				# output_data = kpf1_from_fits(output_lev1_file, data_type = data_type)
				obs_date_time = GetHeaderValue(output_data,'DATE-MID')
				if do_db_query_for_before_after_master_files == True:
					# There is a call to calibration lookup in this sub-recipe. Maybe we don't need it.
					invoke_subrecipe("recipes/wls_interpolation.subrecipe") 
					output_data = interpolated_l1
				else:
					for idx in ccd_idx:
						if wave_fits[idx] != None and exists(wave_fits[idx]):
							# wavecal_data will be replaced by wavelength interpolation.
							wavecal_data = kpf1_from_fits(wave_fits[idx], data_type=data_type)
							for ext in wave_to_ext[idx]:
								ExtCopy(wavecal_data, ext, ext, to_data_model=output_data) # only this needs changed.
								# HTI unclear if the output_data is saved and needs to be reopened
					SetHeaderValue(output_data, 'WLSFILE', wave_fits[0])

				# Add blaze extensions
				if exists(smooth_lamp_file):
					smooth_lamp_l1 = kpf1_from_fits(smooth_lamp_file, data_type=data_type) #smooth lamp file
					input_lev_1d_to_addblaze = output_data
					blaze_output_list = AddBlaze(input_lev_1d_to_addblaze, smooth_lamp_l1)
					exit_code = blaze_output_list[0]
					new_l1_obj = blaze_output_list[1]
					print("exit_code from add blaze")
					print(exit_code)
					if exit_code == 1:
						output_data = new_l1_obj 

				# Quality Control - L1 level
				# (this should be moved below CaHK, but there are several to_fits calls for L1 -- let's fix this)
				# data_level_str = 'L1'
				# kpf_object = output_data
				# invoke_subrecipe("./recipes/quality_control.subrecipe")
				# invoke_subrecipe("./recipes/diagnostics.subrecipe")
				# output_data = kpf_object
				# result = to_fits(output_data, output_lev1_file) #remove extra to fits #1

            # HTI: Keep do_bc in 2D -> L1 for historical reasons.
			if do_bc:# and exists(output_lev1_file): # output_lev1 only exists in memory
				print("Doing barycentric correction on L1 data: "+output_lev1_file)
				# add bary correction result to existing L1 file
				# if not output_data:
				# 	output_data = kpf1_from_fits(output_lev1_file, data_type = data_type) 
				total_orders = 0
				for idx in ccd_idx:
					total_orders = total_orders + orders_per_ccd[idx]

				# all extensions of same ccd in wls has the same data
				for idx in ccd_idx:
					output_data = BaryCorrTable(lev0_data, output_data, total_orders, orders_per_ccd[idx],
								start_bary_index=s_bary_idx[idx], wls_ext=wave_to_ext[idx][0])

				# Quality Control - L1 level
				# (this should be moved below CaHK, but there are several to fits calls for L1 -- let's fix this)
				# data_level_str = 'L1'
				# kpf_object = output_data
				# invoke_subrecipe("./recipes/quality_control.subrecipe")
				# invoke_subrecipe("./recipes/diagnostics.subrecipe")
				# output_data = kpf_object

				# result = to_fits(output_data, output_lev1_file)

			# do ca_hk extraction
			if do_hk:
				# add ca_hk extraction result to existing L1 file or create a new L1 file if L1 file doesn't exist
				# if not exists(output_lev1_file):
				# 	output_data = None
				# else:
				# 	output_data = kpf1_from_fits(output_lev1_file, data_type = data_type)
				# 7/2025: output_data exists only in memory here.

				output_data_cahk = CaHKExtraction(lev0_data, hk_trace_table, hk_fiber_list, output_data, output_exts=hk_spec_exts,
						output_wave_exts=hk_wave_exts,
						dark=hk_dark_data, wave_files=hk_wavelength_tables)
				if output_data_cahk != None:
					output_data = output_data_cahk

			# etalon drift correction
			# output_data = kpf1_from_fits(output_lev1_file, data_type = data_type) #Until the cahk portion is fixed, the output_data needs to be redefined.
			DO_DRIFT = True
			if DO_DRIFT == True:
				print('Starting Drift Correction on L1 data: ' + output_lev1_file)
				invoke_subrecipe("recipes/drift_correction.subrecipe") # The variable output_data is used as the primary input to the drift module.
				output_data = output_l1 # output_l1 is newly defined in the drift correction subrecipe.


			# Quality Control - L1 level
			# (this should be consolidated with QC above, but there are several to fits calls for L1 -- let's fix this)
			data_level_str = 'L1'
			kpf_object = output_data
			obj = GetHeaderValue(kpf_object, 'OBJECT')
			invoke_subrecipe("./recipes/quality_control.subrecipe")
			invoke_subrecipe("./recipes/diagnostics.subrecipe")
			output_data = kpf_object
			# result = to_fits(output_data, output_lev1_file) # PRIMARY SAVE
			result = to_fits(output_data, output_lev1_file)