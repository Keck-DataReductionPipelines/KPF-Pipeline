# general imports.
from modules.Utils.string_proc import str_replace
from modules.Utils.data_handler import GetHeaderValue
from modules.Utils.data_handler import SetHeaderValue
from modules.calibration_lookup.src.calibration_lookup import CalibrationLookup

# masters:
masters_data_dir = config.ARGUMENT.masters_dir
run_masters = config.ARGUMENT.run_masters

# Add the file_list at the top level and redefine if needed
if context.watch:
    input_filename = context.file_path
    
    # Initialize so the conditionals work downstream
    l0_filename_masters = ''
    l1_filename_masters = ''
    l2_filename_masters = ''

    l0_filename_science = ''
    d2_filename_science = ''
    l1_filename_science = ''
    l2_filename_science = ''

    if run_masters:
        # L0 -> L1  file paths
        l0_filename_masters = input_filename # masters run here have no suffix.
    else:
        # L0 -> 2D  file paths
        # Determing what level is being watched.
        if not '_2D.fits' in input_filename and not '_L1.fits' in input_filename and not '_L2.fits' in input_filename:
            print("Input file appears to be L0 file: " + str(input_filename))
            l0_filename_science = input_filename  
            d2_filename_temp    = str_replace(l0_filename_science, '/L0/', '/2D/')
            d2_filename_science = str_replace(d2_filename_temp, '.fits', '_2D.fits')
            l1_filename_science = str_replace(d2_filename_science, '2D', 'L1') # Replaces both instances
            l2_filename_science = str_replace(l1_filename_science, 'L1', 'L2')
        elif '_2D.fits' in input_filename:
            print("Input file appears to be 2D file: " + str(input_filename))
            d2_filename_science = input_filename           
            l1_filename_science = str_replace(d2_filename_science, '2D', 'L1') # Replaces both instances
            l2_filename_science = str_replace(l1_filename_science, 'L1', 'L2')

        elif '_L1.fits' in input_filename:
            print("Input file appears to be L1 file: " + str(input_filename))
            l1_filename_science = input_filename
            l2_filename_science = str_replace(l1_filename_science, 'L1', 'L2')
        elif '_L2.fits' in input_filename:
            print("Input file appears to be L2 file: " + str(input_filename))   
            l2_filename_science = input_filename

    # 2D -> L1 file paths (derived from 2D files, not L0)
    if run_masters:
        # For masters, L1 files are derived from L0 files
        if not '_L1.fits' in input_filename and not '_L2.fits' in input_filename:  # Only if not already L1
            l1_filename_temp = str_replace(input_filename, '/L0/', '/L1/')
            l1_filename_masters = str_replace(l1_filename_temp, '.fits', '_L1.fits')
            print("l1_filename_masters: " + l1_filename_masters)
        
    # Step 3: L1 -> L2 file paths (derived from L1 files)
    if run_masters:
        l2_filename_masters = str_replace(l1_filename_masters, 'L1', 'L2')

    print("---------l0_filename_science: " + l0_filename_science)
    print("---------2d_filename_science: " + d2_filename_science)
    print("---------l1_filename_science: " + l1_filename_science)
    print("---------l2_filename_science: " + l2_filename_science)
    print("----------l1_filename_masters: " + l1_filename_masters)
    print("----------l2_filename_masters: " + l2_filename_masters)

# Set in kpf_drp.cfg
do_l0_to_2d_science = config.ARGUMENT.do_l0_to_2d_science 
do_2d_to_l1_science = config.ARGUMENT.do_2d_to_l1_science
do_only_drift       = config.ARGUMENT.do_only_drift
do_l1_to_l2_science = config.ARGUMENT.do_l1_to_l2_science

# Masters runs with only L1 and L2 files with config kpf_masters_l1.cfg
do_l0_to_l1_masters = config.ARGUMENT.do_l0_to_l1_masters
do_l1_to_l2_masters = config.ARGUMENT.do_l1_to_l2_masters

# L0 files: have .fits but no level suffixes

# SCIENCE
if not run_masters:
    if do_l0_to_2d_science:# and (not '_2D.fits' in d2_filename_science and not '_L1.fits' in d2_filename_science and not '_L2.fits' in d2_filename_science):
        print("RUNNING L0->2D PROCESSING for " + str(input_filename))
        # Silent inputs are input_filename and d2_filename_science
        invoke_subrecipe("./recipes/kpf_l0_to_2d_science.recipe")

    if do_2d_to_l1_science and '_2D.fits' in d2_filename_science:
        print("RUNNING 2D->L1 PROCESSING for " + str(d2_filename_science))
        # Silent inputs are d2_filename_science and l1_filename_science
        invoke_subrecipe("./recipes/kpf_2d_to_l1_science.recipe")

    # Set in config appropriately. False for science and masters, true for drift only.
    #  Use kpf_drp_do_only_drift.cfg to run drift correction only.
    if do_only_drift and '_L1.fits' in l1_filename_science:
        print("RUNNING L1->L2 PROCESSING WITH ONLY DRIFT CORRECTION for L1 file, updating L2 file. ")
        # Silent inputs are l1_filename_science and l2_filename_science
        invoke_subrecipe("./recipes/kpf_drp_update_wls.recipe")

    if do_l1_to_l2_science and '_L1.fits' in l1_filename_science:
        # This condition is done with or without do_only_drift.
        print("RUNNING L1->L2 PROCESSING for " + str(l1_filename_science))
        # Silent inputs are  l1_filename_science and l2_filename_science
        invoke_subrecipe("./recipes/kpf_l1_to_l2_science.recipe")

# MASTERS
if run_masters:
    if do_l0_to_l1_masters and (not '_L1.fits' in l0_filename_masters and not '_L2.fits' in l0_filename_masters):
        print("RUNNING L0->L1 PROCESSING for " + str(l0_filename_masters))
        # invoke_subrecipe("./recipes/kpf_l0_to_l1_masters.recipe") # LETS MAKE IT THIS!
        invoke_subrecipe("./recipes/kpf_2d_to_l1_science.recipe") 

    if do_l1_to_l2_masters and '_L1.fits' in l1_filename_masters:
        print("RUNNING L1->L2 PROCESSING for " + str(l1_filename_masters))
        # invoke_subrecipe("./recipes/kpf_l1_to_l2_masters.recipe") # LETS MAKE IT THIS!
        invoke_subrecipe("./recipes/kpf_l1_to_l2_science.recipe") 




