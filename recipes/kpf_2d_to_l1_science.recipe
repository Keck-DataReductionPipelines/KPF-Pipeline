## path containing ca_hk trace file and wavelength table
input_hk_data_dir = output_dir
hk_fiber_list = config.ARGUMENT.hk_fiber_list
hk_spec_exts = config.ARGUMENT.hk_extract_exts
hk_wave_exts = config.ARGUMENT.hk_wave_exts
hk_trace_table = input_hk_data_dir + config.ARGUMENT.hk_trace_path
hk_wavelength_csvs = config.ARGUMENT.hk_wavelength_path
hk_wavelength_tables = []
for hk_w in hk_wavelength_csvs:
	hk_wavelength_tables = hk_wavelength_tables + [input_hk_data_dir + hk_w]

flat_file_date_dir = context.date_dir

input_flat_file = output_dir + flat_file_date_dir + '/kpf_' + flat_file_date_dir + '_master_flat.fits'
if not exists(input_flat_file): 
	input_flat_file = output_dir + 'masters/' + flat_file_date_dir + '/kpf_' + flat_file_date_dir + '_master_flat.fits'

# HTI THIS IS ONE OF THE FIRST PLACES THAT AN EXTERNAL ROUTINE IS CALLED. EVERYTHING ABOVE THIS IS PREPARING THE VARIABLES.
#  I WONDER HOW MUCH OF ABOVE HERE CAN BE MOVED TO A CONFIGURATION FILE.

if not exists(input_flat_file): # If the input_flat_file is correct, we never need this. We want to avoid more calls to calibration lookup.
    # CalibrationLookup input datetime is one minute past the midnight boundary to ensure it is well past the selection threshold.
    dt_string =  date_dir[0] + date_dir[1] + date_dir[2] + date_dir[3] +\
             "-" + date_dir[4] + date_dir[5] + "-" + date_dir[6] + date_dir[7] + "T00:01:00.000000"
    print("Using datetime string for calibration lookup: "+dt_string)
    cals = CalibrationLookup(dt_string)
    input_flat_file = cals['flat']

trace_list = []
if do_spectral_extraction or do_hk or do_bc:# HTI: I think we do not need this conditional anymore.

	# prepare bias, dark data for ca_hk
	if do_hk:
		hk_dark_data = config.ARGUMENT.hk_dark_fits
		hk_bias_data = config.ARGUMENT.hk_bias_fits
		if hk_dark_data:
			hk_dark_data = kpf0_from_fits(input_hk_data_dir + hk_dark_data, data_type = data_type)
		else:
			hk_dark_data = None

		if hk_bias_data:
			hk_bias_data = kpf0_from_fits(input_hk_data_dir + hk_bias_data, data_type=data_type)
		else:
			hk_bias_data = None

	# Initialize order_mask variable, check below for existence to avoid re-opening
	order_mask = None
	master_flat = None

	# loop through ccd and L0 to do spectral extraction
	if run_masters:
		input_2d_or_l0_filename = l0_filename_masters
		output_l1_filename = l1_filename_masters
	else: #SCIENCE
		input_2d_or_l0_filename = d2_filename_science
		output_l1_filename = l1_filename_science
	
	# lev0_data is KPF0 instance for input_lev0_file
	lev0_data = kpf0_from_fits(input_2d_or_l0_filename, data_type=data_type)
	dt_string = GetHeaderValue(lev0_data, 'DATE-MID')
	if dt_string is None:
		dt_string = GetHeaderValue(lev0_data,'DATE') # smooth lamp had not date-mid keyword')
	cals = CalibrationLookup(dt_string)
	
	start_order = cals['start_order']
	output_order_trace = cals['ordertrace']
	order_trace_flat = cals['flat']
	smooth_lamp_file = str_replace(cals['smoothlamp'], '.fits', '_L1.fits')

	# produce level 1 by spectral extraction if overwrite or L1 file doesn't exist
	if (overwrite or not exists(l1_filename_science)):		# Define the order mask - load from CalibrationLookup result

		order_mask = None
		# create order mask for background subtraction
		for idx in ccd_idx:
			ccd = ccd_list[idx]
			# get order trace file name defined in config file
			output_lev0_trace_csv = str_replace(input_flat_file, fits_ext, '_' + ccd + csv_ext)
			trace_list = trace_list + [output_lev0_trace_csv]
			trace_file = trace_list[idx]
		# for idx in ccd_idx:
			if orderlet_widths_ccds:
				orderlet_widths = orderlet_widths_ccds[idx]
			else:
				orderlet_widths = []
			order_mask = OrderMask(lev0_data, order_mask, orderlet_names=orderlet_names[idx],
					start_order=start_order[idx], trace_file=trace_list[idx],
					data_extension=ccd_list[idx],
					orderlet_widths=orderlet_widths, full_coverage=1)
		
		# Scattered light now handled with StrayLight module down below, and the order_mask is needed for that.
		# I THINK we need this for variance extension creation.
		# if order_mask != None:
		# 	lev0_data = ImageProcessing(lev0_data, order_mask, ccd_list, data_type, None)
		op_data = None
		
		# Greg to do: Add in necessary masters processing that adds varance extensions to KPF0 object.
		#  Add 
		# if run_masters:
			# Call to something similar to kpf_l0_to_2d_science.recipe for masters
			# inherited variables are defined here.
			# The primary thing we need from this subrecipe is the variance.
			# But we may also need to do the background subtraction and bias removal.
			# invoke_subrecipe("./recipes/???.subrecipe")
		
		stray_light_output_list = StrayLight(lev0_data, order_mask)
		lev0_data = stray_light_output_list[1]
		if master_flat == None:
			master_flat = kpf0_from_fits(cals['flat'])
		# The spectral extraction operates on both CCDs simultaneously.
		
		print("=== CALIBRATION VALUES FOR SPECTRAL EXTRACTION ===")
		print(f"ordertrace[0]: {cals['ordertrace'][0]}")
		print(f"ordertrace[1]: {cals['ordertrace'][1]}")
		print(f"start_order[0]: {cals['start_order'][0]}")
		print(f"start_order[1]: {cals['start_order'][1]}")
		print(f"master_flat: {master_flat}")
		print("================================================")
		
		spectral_extraction_output_list = SpectralExtraction(lev0_data, 
															 master_flat, 
															 cals['ordertrace'][0], 
															 cals['ordertrace'][1], 
															 cals['start_order'][0], 
															 cals['start_order'][1]
															)
		# SpectralExtraction returns [exit_code, op_data, ...other values...]
		output_data= spectral_extraction_output_list[1]

		# copy wls to the proper extension of lev1 data
		if do_sp_wavecopy:# and exists(output_lev1_file): output_lev1 only exists in memory
			obs_date_time = GetHeaderValue(output_data,'DATE-MID')
			if do_db_query_for_before_after_master_files == True:
				invoke_subrecipe("recipes/wls_interpolation.subrecipe") 
				output_data = interpolated_l1
			else: # Not sure when this conditional is used.
				for idx in ccd_idx:
					if wave_fits[idx] != None and exists(wave_fits[idx]):
						# wavecal_data will be replaced by wavelength interpolation.
						wavecal_data = kpf1_from_fits(wave_fits[idx], data_type=data_type)
						for ext in wave_to_ext[idx]:
							ExtCopy(wavecal_data, ext, ext, to_data_model=output_data) # only this needs changed.
							# HTI unclear if the output_data is saved and needs to be reopened
				SetHeaderValue(output_data, 'WLSFILE', wave_fits[0])
			# Add blaze extensions
			# Not working as of 18 August 2025.
			# if exists(smooth_lamp_file):
			# 	smooth_lamp_l1 = kpf1_from_fits(smooth_lamp_file, data_type=data_type) #smooth lamp file
			# 	input_lev_1d_to_addblaze = output_data
			# 	blaze_output_list = AddBlaze(input_lev_1d_to_addblaze, smooth_lamp_l1)
			# 	exit_code = blaze_output_list[0]
			# 	new_l1_obj = blaze_output_list[1]
			# 	print("exit_code from add blaze: "+str(exit_code))
			# 	if exit_code == 1:
			# 		output_data = new_l1_obj 

        # HTI: Keep do_bc in 2D -> L1 for historical reasons.
		if do_bc:# and exists(output_lev1_file): # output_lev1 only exists in memory
			# if not output_data:
			# 	output_data = kpf1_from_fits(output_lev1_file, data_type = data_type) 
			total_orders = 0
			for idx in ccd_idx:
				total_orders = total_orders + orders_per_ccd[idx]
			# all extensions of same ccd in wls has the same data
			for idx in ccd_idx:
				output_data = BaryCorrTable(lev0_data, output_data, total_orders, orders_per_ccd[idx],
							start_bary_index=s_bary_idx[idx], wls_ext=wave_to_ext[idx][0])#,config=bary_config). Defining the config like this didn't work
		# do ca_hk extraction
		if do_hk:
			# DOUBLE CHECK IF THE FIRST ARGUMENT SHOULD BE OUTPUT_DATA FROM ABOVE OR LEV0_DATA.
			output_data_cahk = CaHKExtraction(lev0_data, hk_trace_table, hk_fiber_list, output_data, output_exts=hk_spec_exts,
					output_wave_exts=hk_wave_exts,
					dark=hk_dark_data, wave_files=hk_wavelength_tables)
			if output_data_cahk != None:
				output_data = output_data_cahk

		# etalon drift correction
		DO_DRIFT = True # REPLACE WITH CONFIG VARIABLE.
		if DO_DRIFT == True and not run_masters: # No drift correction for masters.
			print('Starting Drift Correction on L1 data: ' + output_l1_filename)
			invoke_subrecipe("recipes/drift_correction.subrecipe") # The variable output_data is used as the primary input to the drift module.
			output_data = output_l1 # output_l1 is newly defined in the drift correction subrecipe.
		# Quality Control - L1 level
		data_level_str = 'L1'
		kpf_object = output_data
		obj = GetHeaderValue(kpf_object, 'OBJECT')
		invoke_subrecipe("./recipes/quality_control.subrecipe")
		invoke_subrecipe("./recipes/diagnostics.subrecipe")
		output_data = kpf_object
		result = to_fits(output_data, output_l1_filename) # PRIMARY SAVE