# IS WAVE_FITS DEPRECATED DUE TO THE DATABASE QUERY FOR NEAREST MASTER FILES? WHAT ABOUT A DEFAULT WLS?
wave_fits = []
for wls in wls_list:
	wave_fits = wave_fits + [output_dir + wls]

#    origin: origin of the image to be processed
data_row_range = [0, -1]
data_col_range = [0, -1]
origin = [data_col_range[0], data_row_range[0]]

lev0_flat_pattern = config.ARGUMENT.flat_file # HTI: How does this fit into masters?
orderlet_gap_pixels = config.ARGUMENT.orderlet_gap_pixels
