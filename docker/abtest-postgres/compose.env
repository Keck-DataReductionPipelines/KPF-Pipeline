# Environment overrides used by scripts/abtest_pg.py to avoid loading the repo-level .env
# Set values here or export them in your shell before invoking the helper.

# Host port that forwards to Postgres 5432 inside the container.
ABTEST_PG_HOST_PORT=7125
# Host/port used by tooling outside Docker (clone script, make docker). If you
# prefer a different host alias, set ABTEST_HOST_OVERRIDE as well.
ABTEST_DB_SERVER=127.0.0.1
ABTEST_DB_PORT=7125
ABTEST_DB_USER=kpfopsuser
ABTEST_DB_PASS=kpfopspass
ABTEST_TSDB_SERVER=127.0.0.1
ABTEST_TSDB_PORT=7125
ABTEST_TSDB_USER=timeseriesopsuser
ABTEST_TSDB_PASS=timeseriesopspass
