# Add the file_list at the top level and redefine if needed
if context.watch:
    # l0_file_list = find_files(context.file_path)
    l0_file_list = context.file_path
    # lev0_file_path = context.file_path

    # Derive corresponding file paths for other levels
    d2_file_list = []
    l1_file_list = []
    l2_file_list = []
    
    # for l0_file in l0_file_list:
        # 2D -> L1 conversion
        # masters filenames should not have 2D prefixes at this point

    # Step 1: L0 -> 2D file paths
    if run_masters:
         d2_file_list = l0_file_list # masters run here have no suffix.
    else:
        d2_file = str_replace(l0_file_list, '/L0/', '/2D/')
        d2_file = str_replace(d2_file, '.fits', '_2D.fits')
        d2_file_list = d2_file # Run as single value.
    
    # Step 2: 2D -> L1 file paths (derived from 2D files, not L0)
    if run_masters:
        # For masters, L1 files are derived from L0 files
        l1_file = str_replace(l0_file_list, '/L0/', '/L1/')
        l1_file = str_replace(l1_file, '.fits', '_L1.fits')
    else:
        # For non-masters, L1 files are derived from 2D files
        l1_file = str_replace(d2_file_list, '/2D/', '/L1/')
        l1_file = str_replace(l1_file, '_2D.fits', '_L1.fits')
    l1_file_list = l1_file # Run as single value.
    
    # Step 3: L1 -> L2 file paths (derived from L1 files)             
    l2_file = str_replace(l1_file_list, '/L1/', '/L2/')
    l2_file = str_replace(l2_file, '_L1.fits', '_L2.fits')
    l2_file_list = l2_file # Run as single value.

else:
    # search_string = config.WATCHFOR_L0.input_dir + "/" + date_dir + '/*.fits'
    # file_path = find_files(search_string)

    # Batch mode: find all files for the date
    date_dir = context.date_dir
    
    # Define search patterns for each level
    l0_pattern = config.WATCHFOR_L0.input_dir + "/" + date_dir + '/*.fits'
    d2_pattern = config.WATCHFOR_2D.input_dir + "/" + date_dir + '/*_2D.fits'
    l1_pattern = config.WATCHFOR_L1.input_dir + "/" + date_dir + '/*_L1.fits'

    # Find files for each level
    l0_file_list = find_files(l0_pattern)
    d2_file_list = find_files(d2_pattern)
    l1_file_list = find_files(l1_pattern)

# Get the current input file to determine what processing should run
current_file = str(context.file_path)
print("CURRENT INPUT FILE: " + current_file)

# File type detection for conditional processing using basic string operations
# Directly use the conditions in the if statements to avoid unused variables

print("FILE TYPE DETECTION:")
print("  has_2d_suffix: " + str('_2D.fits' in current_file))
print("  has_l1_suffix: " + str('_L1.fits' in current_file))
print("  has_l2_suffix: " + str('_L2.fits' in current_file))
print("  has_fits_ext: " + str('.fits' in current_file))

# Masters runs with only L1 and L2 files with config kpf_masters_l1.cfg
do_l0_to_2d = config.ARGUMENT.do_l0_to_2d# masters is no, science is yes.
# L0 files: have .fits but no level suffixes
if do_l0_to_2d and (('.fits' in current_file and not '_2D.fits' in current_file and not '_L1.fits' in current_file and not '_L2.fits' in current_file) or run_masters):
    print("RUNNING L0->2D PROCESSING")
    invoke_subrecipe("./recipes/kpf_l0_to_2D_only.recipe") 

# BEGIN 2D to L1. Set desired levels from configs and redefine the level specific keywords in the conditionals.
do_2d_to_l1 = config.ARGUMENT.do_2d_to_l1
if do_2d_to_l1 and ('_2D.fits' in current_file or (run_masters and ('.fits' in current_file and not '_2D.fits' in current_file and not '_L1.fits' in current_file and not '_L2.fits' in current_file))):
    print("RUNNING 2D->L1 PROCESSING")
    invoke_subrecipe("./recipes/kpf_2d_to_l1.recipe")

# Level 1 to level 2 processing.
# observations with 'slewcal' or etalon in the name should not get processed in this next step
do_l1_to_l2 = config.ARGUMENT.do_l1_to_l2
if do_l1_to_l2 and '_L1.fits' in current_file:
    if  'slewcal' in current_file or 'etalon' in current_file:
        print("SKIPPING L1->L2 PROCESSING FOR: " + current_file)
    else:
        print("RUNNING L1->L2 PROCESSING")
        invoke_subrecipe("./recipes/kpf_l1_to_l2.recipe")    

