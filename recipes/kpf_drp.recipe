# Add the file_list at the top level and redefine if needed
if context.watch:
    input_filename = context.file_path

    
    # Initialize so the conditionals work downstream
    l0_filename_masters = ''
    l1_filename_masters = ''
    l2_filename_masters = ''

    l0_filename_science = ''
    d2_filename_science = ''
    l1_filename_science = ''
    l2_filename_science = ''

    if run_masters:
        # Step 1: L0 -> L1  file paths
        l0_filename_masters = input_filename # masters run here have no suffix.
    else:
        # Step 1: L0 -> 2D  file paths
        l0_filename_science = input_filename  
        d2_filename_temp = str_replace(input_filename, '/L0/', '/2D/')
        if not '_2D.fits' in d2_filename_temp:  # Only if not already 2D
            d2_filename_science = str_replace(d2_filename_temp, '.fits', '_2D.fits')
            print("d2_filename_science: " + d2_filename_science)
        else:
            print("d2_filename_science already has _2D.fits suffix: " + d2_filename_temp)

    # Step 2: 2D -> L1 file paths (derived from 2D files, not L0)
    if run_masters:
        # For masters, L1 files are derived from L0 files
        if not '_L1.fits' in input_filename:  # Only if not already L1
            l1_filename_temp = str_replace(input_filename, '/L0/', '/L1/')
            l1_filename_masters = str_replace(l1_filename_temp, '.fits', '_L1.fits')
    else:
        # For non-masters, L1 files are always derived from 2D files
        l1_filename_science = str_replace(d2_filename_science, '2D', 'L1') # Replaces both instances

    # Step 3: L1 -> L2 file paths (derived from L1 files)
    l2_filename_science = str_replace(l1_filename_science, 'L1', 'L2')
    # l2_filename = str_replace(l2_filename, '_L1.fits', '_L2.fits')


