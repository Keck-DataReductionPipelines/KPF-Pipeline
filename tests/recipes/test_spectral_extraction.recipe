from modules.Utils.data_handler import GetHeaderValue

target_2D_file = '/data/2D/20241022/KP.20241022.48910.02_2D.fits'
target_2D_obj = kpf0_from_fits(target_2D_file)  # recipe language, automatically imports I/O

obs_date_time = GetHeaderValue(D2_obj,'DATE-MID')
cals = CalibrationLookup(obs_date_time, subset=['masterflat', 'ordermask', 'ordertrace', 'start_order'])
masterflat = kp0_from_fits(cals['masterflat])
ordermask = kpf0_from_fits(cals['ordermask'])
trace_green = cals['ordertrace'][0]              # this is a filepath
trace_red = cals['ordertrace'][1]
start_order = cals['start_order']

stray_light_image, stray_light_mask = StrayLight(target_2D_obj, ordermask)
spectral_extraction_output_list = SpectralExtraction(target_2D_obj, masterflat, stray_light_image, trace_green, trace_red, start_order)

exit_code = spectral_extraction_output_list[0]
target_l1 = spectral_extraction_output_list[1]